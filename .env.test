NODE_ENV=test
PORT=3001

DATABASE_URL="mysql://root:password@localhost:3306/db_name"
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="db_name"
DATABASE_HOST="localhost"
DATABASE_PORT=3306

JWT_ACCESS_SECRET="test-access-secret-minimum-32-characters"
JWT_REFRESH_SECRET="test-refresh-secret-minimum-32-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_DEFAULT_LIMIT=1000
CACHE_TTL_MS=1000
